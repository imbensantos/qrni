{
  "name": "qrni",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:app": "npm run dev --workspace=apps/app",
    "dev:landing": "npm run dev --workspace=apps/landing",
    "build:app": "npm run build --workspace=apps/app",
    "build:landing": "npm run build --workspace=apps/landing",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "dependencies": {
    "convex": "^1.33.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
