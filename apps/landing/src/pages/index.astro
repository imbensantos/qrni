---
import Layout from '../layouts/Layout.astro';

const appUrl = import.meta.env.PUBLIC_APP_URL;
if (!appUrl) {
  console.warn('PUBLIC_APP_URL is not set. Links to the app will be broken.');
}
---

<Layout
  title="QRni — Free QR Code Generator | No Sign-Up Needed"
  description="Generate QR codes instantly for free and shorten URLs for your events. No sign-up, no limits. Organize links with namespaces, set custom slugs, and invite your team."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-logo">QRni</h1>
      <p class="hero-headline">Your free, instant QR code maker — no sign-up needed!</p>
      <a href={appUrl} class="cta-btn">Generate QR Code</a>

      <div class="hero-mockup">
        <div class="mockup-window">
          <img src="/app-screenshot.png" alt="QRni app generating a QR code from a URL" class="mockup-screenshot" />
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="how-it-works">
    <div class="container">
      <h2 class="section-title">How It Works</h2>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-number">1</div>
          <div class="step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
            </svg>
          </div>
          <h3 class="step-title">Paste your URL</h3>
          <p class="step-desc">Copy any link and paste it into the input field.</p>
        </div>

        <div class="step-card">
          <div class="step-number">2</div>
          <div class="step-icon">
            <img src="/animated-qr-icon.gif" alt="QR code" width="48" height="48" />
          </div>
          <h3 class="step-title">QR code generates instantly</h3>
          <p class="step-desc">Your QR code appears in real-time as you type.</p>
        </div>

        <div class="step-card">
          <div class="step-number">3</div>
          <div class="step-icon">
            <img src="/animated-download-icon.gif" alt="Download" width="48" height="48" />
          </div>
          <h3 class="step-title">Download as PNG</h3>
          <p class="step-desc">One click to save your QR code as a high-quality image.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <div class="container">
      <h2 class="section-title">Why QRni?</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
            </svg>
          </div>
          <h3>Free forever</h3>
          <p>No hidden costs, no premium tiers. Just free QR codes.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <line x1="17" y1="11" x2="22" y2="11" />
            </svg>
          </div>
          <h3>No sign-up required</h3>
          <p>Start generating instantly. No accounts, no forms.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
            </svg>
          </div>
          <h3>Instant generation</h3>
          <p>QR codes render in real-time as you type your URL.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
          </div>
          <h3>High-quality PNG download</h3>
          <p>Crisp, clean QR codes ready for print or digital use.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- URL Shortener -->
  <section class="url-shortener">
    <div class="container">
      <div class="shortener-badge">New</div>
      <h2 class="section-title">Shorten URLs for your events</h2>
      <p class="section-subtitle">
        Keep your links clean and memorable. Perfect for conferences, workshops, pop-ups — anywhere you need QR codes that actually make sense.
      </p>

      <div class="shortener-grid">
        <div class="shortener-card shortener-card--highlight">
          <div class="shortener-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
              <path d="M16 3H8L2 7h20l-6-4z" />
            </svg>
          </div>
          <h3>Namespaces for every event</h3>
          <p>Organize your links under a shared namespace — keep your annual gala, weekly markets, and product launches neatly separated.</p>
        </div>

        <div class="shortener-card">
          <div class="shortener-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z" />
            </svg>
          </div>
          <h3>Custom slugs</h3>
          <p>Choose exactly what comes after the slash. Turn <span class="slug-example">qrni.co/xyz99</span> into something like <span class="slug-example">qrni.co/artfest-map</span>.</p>
        </div>

        <div class="shortener-card">
          <div class="shortener-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
          </div>
          <h3>Invite your team</h3>
          <p>Share a namespace with your crew. Everyone can create and manage links for the event without stepping on each other's toes.</p>
        </div>
      </div>

      <div class="shortener-cta">
        <a href={appUrl} class="cta-btn cta-btn--secondary">Try URL Shortener</a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container">
      <div class="powered-by">
        <span>Powered by</span>
        <a href="https://imbensantos.com" target="_blank" rel="noopener noreferrer">
          <img src="/imbento-logo-white.svg" alt="imBento" class="imbento-logo" />
        </a>
      </div>
      <p class="attribution">
        Animated icons by <a href="https://www.flaticon.com" target="_blank" rel="noopener noreferrer">Flaticon</a>
      </p>
    </div>
  </footer>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 5rem 0 3rem;
    text-align: center;
  }

  .hero-logo {
    font-size: 4.5rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .hero-headline {
    font-size: 1.3rem;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 600;
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-btn {
    display: inline-block;
    padding: 0.9rem 2.5rem;
    background: linear-gradient(135deg, #a78bfa, #ec4899);
    color: #fff;
    border-radius: 1rem;
    font-size: 1.1rem;
    font-weight: 700;
    font-family: 'Nunito', sans-serif;
    box-shadow: 0 4px 20px rgba(167, 139, 250, 0.45);
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(167, 139, 250, 0.6);
  }

  .cta-btn:active {
    transform: translateY(0);
  }

  /* Mockup */
  .hero-mockup {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
  }

  .mockup-window {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.15);
    width: 100%;
    max-width: 380px;
    overflow: hidden;
  }

  .mockup-screenshot {
    display: block;
    width: 100%;
    height: auto;
  }

  /* How It Works */
  .how-it-works {
    padding: 4rem 0;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .step-card {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border-radius: 16px;
    padding: 2rem 1.5rem;
    text-align: center;
    position: relative;
  }

  .step-number {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, #a78bfa, #ec4899);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 800;
    color: #fff;
  }

  .step-icon {
    margin-bottom: 1rem;
    color: #fff;
  }

  .step-icon img {
    opacity: 0.9;
  }

  .step-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .step-desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.5;
  }

  /* Features */
  .features {
    padding: 4rem 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border-radius: 16px;
    padding: 2rem;
  }

  .feature-icon {
    margin-bottom: 1rem;
    color: #fff;
  }

  .feature-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.5;
  }

  /* URL Shortener */
  .url-shortener {
    padding: 4rem 0;
    text-align: center;
  }

  .shortener-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: linear-gradient(135deg, #a78bfa, #ec4899);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    max-width: 520px;
    margin: 0.75rem auto 2.5rem;
    line-height: 1.6;
  }

  .shortener-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    text-align: left;
  }

  .shortener-card {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border-radius: 16px;
    padding: 2rem;
  }

  .shortener-card--highlight {
    background: rgba(167, 139, 250, 0.25);
    border: 1px solid rgba(167, 139, 250, 0.4);
  }

  .shortener-card__icon {
    margin-bottom: 1rem;
    color: #fff;
  }

  .shortener-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #fff;
  }

  .shortener-card p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.5;
  }

  .slug-example {
    font-family: monospace;
    font-size: 0.85em;
    background: rgba(255, 255, 255, 0.15);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    white-space: nowrap;
  }

  .shortener-cta {
    margin-top: 0.5rem;
  }

  .cta-btn--secondary {
    background: rgba(255, 255, 255, 0.2);
    border: 2px solid rgba(255, 255, 255, 0.5);
    box-shadow: none;
  }

  .cta-btn--secondary:hover {
    background: rgba(255, 255, 255, 0.3);
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.2);
  }

  /* Footer */
  .site-footer {
    padding: 3rem 0 2rem;
    text-align: center;
  }

  .powered-by {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 1rem;
  }

  .imbento-logo {
    height: 4rem;
    vertical-align: middle;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .imbento-logo:hover {
    opacity: 1;
  }

  .attribution {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .attribution a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .attribution a:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }

    .features-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }

    .shortener-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto 2.5rem;
    }

    .hero-logo {
      font-size: 3.5rem;
    }

    .hero-headline {
      font-size: 1.1rem;
    }
  }

  @media (max-width: 480px) {
    .hero-logo {
      font-size: 2.8rem;
    }

    .hero-headline {
      font-size: 1rem;
    }

    .mockup-window {
      max-width: 300px;
    }
  }
</style>
