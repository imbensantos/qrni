{
  "$comment": "Vercel rewrites do not support env vars. The Convex deployment URL below must be updated manually when the deployment changes. It should match the CONVEX_SITE_URL environment variable configured in the Vercel project settings.",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/profile",
      "destination": "/index.html"
    },
    {
      "source": "/:code([a-zA-Z0-9][a-zA-Z0-9_-]{0,59})",
      "destination": "https://keen-akita-913.convex.site/:code"
    },
    {
      "source": "/:ns([a-z][a-z0-9-]{2,29})/:slug([a-zA-Z0-9_-]{1,60})",
      "destination": "https://keen-akita-913.convex.site/:ns/:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
